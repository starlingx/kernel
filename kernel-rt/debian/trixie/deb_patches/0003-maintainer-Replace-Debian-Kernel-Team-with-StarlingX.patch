From 5954e844a17e55289cc1c5e8289b94bd06bf4749 Mon Sep 17 00:00:00 2001
From: Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>
Date: Wed, 10 Jun 2026 13:29:59 +0300
Subject: [PATCH] maintainer: Replace Debian Kernel Team with StarlingX Kernel Team

Update the Maintainer field in to reflect that this kernel
package is maintained by the StarlingX Kernel Team.

Signed-off-by: Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>
---
 debian/copyright                          | 1 +
 debian/templates/signed.source.control.in | 8 ++++----
 debian/templates/source.control.in        | 8 ++++----
 3 files changed, 9 insertions(+), 8 deletions(-)

diff --git a/debian/copyright b/debian/copyright
index ee6611a9d9..dc5f2a41dc 100644
--- a/debian/copyright
+++ b/debian/copyright
@@ -22,6 +22,7 @@ Files: debian/*
 Copyright: 1996-2006 Manoj Srivastava
            2005-2012 Debian kernel team
            2006-2009 Bastian Blank <waldi@debian.org>
+           2026 StarlingX kernel team
 License: GPL-2
 
 Files:
diff --git a/debian/templates/signed.source.control.in b/debian/templates/signed.source.control.in
index 3edb5a88f5..a892fbd4bd 100644
--- a/debian/templates/signed.source.control.in
+++ b/debian/templates/signed.source.control.in
@@ -1,14 +1,14 @@
 Source: linux-signed@source_suffix@-@arch@
 Section: kernel
 Priority: optional
-Maintainer: Debian Kernel Team <debian-kernel@lists.debian.org>
-Uploaders: Bastian Blank <waldi@debian.org>, maximilian attems <maks@debian.org>, Ben Hutchings <benh@debian.org>, Salvatore Bonaccorso <carnil@debian.org>
+Maintainer: StarlingX Kernel Team <starlingx-discuss@lists.starlingx.io>
+Uploaders: Viorel-Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>, Virgil Bucoci <virgil.bucoci@windriver.com>
 Standards-Version: 4.2.0
 Build-Depends:
  debhelper-compat (= 13),
  python3:any,
  sbsigntool [amd64 arm64],
 Rules-Requires-Root: no
-Vcs-Git: https://salsa.debian.org/kernel-team/linux.git
-Vcs-Browser: https://salsa.debian.org/kernel-team/linux
+Vcs-Git: https://opendev.org/starlingx/kernel.git
+Vcs-Browser: https://opendev.org/starlingx/kernel
 Homepage: https://www.kernel.org/
diff --git a/debian/templates/source.control.in b/debian/templates/source.control.in
index 8999d48c89..3ae07eaf6a 100644
--- a/debian/templates/source.control.in
+++ b/debian/templates/source.control.in
@@ -1,7 +1,7 @@
 Section: kernel
 Priority: optional
-Maintainer: Debian Kernel Team <debian-kernel@lists.debian.org>
-Uploaders: Bastian Blank <waldi@debian.org>, maximilian attems <maks@debian.org>, Ben Hutchings <benh@debian.org>, Salvatore Bonaccorso <carnil@debian.org>
+Maintainer: StarlingX Kernel Team <starlingx-discuss@lists.starlingx.io>
+Uploaders: Viorel-Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>, Virgil Bucoci <virgil.bucoci@windriver.com>
 Standards-Version: 4.2.0
 Build-Depends:
  debhelper-compat (= 13),
@@ -15,6 +15,6 @@ Build-Depends:
 # used by debian/rules.real to build linux-perf
  dh-python <!pkg.linux.notools>,
 Rules-Requires-Root: no
-Vcs-Git: https://salsa.debian.org/kernel-team/linux.git
-Vcs-Browser: https://salsa.debian.org/kernel-team/linux
+Vcs-Git: https://opendev.org/starlingx/kernel.git
+Vcs-Browser: https://opendev.org/starlingx/kernel
 Homepage: https://www.kernel.org/
-- 
2.47.3

