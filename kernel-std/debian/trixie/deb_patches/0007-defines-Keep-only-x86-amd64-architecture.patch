-    [kernelarch.debianarch.packages]
-    libc_dev_cross_only = true
-  [[kernelarch.debianarch]]
-  name = 'mips64el'
-  [[kernelarch.debianarch]]
-  name = 'mips64r6el'
-  [[kernelarch.debianarch]]
-  name = 'mipsel'
-  [[kernelarch.debianarch]]
-  name = 'mipsn32'
-    [kernelarch.debianarch.packages]
-    libc_dev_cross_only = true
-  [[kernelarch.debianarch]]
-  name = 'mipsn32el'
-    [kernelarch.debianarch.packages]
-    libc_dev_cross_only = true
-  [[kernelarch.debianarch]]
-  name = 'mipsn32r6'
-    [kernelarch.debianarch.packages]
-    libc_dev_cross_only = true
-  [[kernelarch.debianarch]]
-  name = 'mipsn32r6el'
-    [kernelarch.debianarch.packages]
-    libc_dev_cross_only = true
-  [[kernelarch.debianarch]]
-  name = 'mipsr6'
-    [kernelarch.debianarch.packages]
-    libc_dev_cross_only = true
-  [[kernelarch.debianarch]]
-  name = 'mipsr6el'
-    [kernelarch.debianarch.packages]
-    libc_dev_cross_only = true
-
-[[kernelarch]]
-name = 'powerpc'
-  [[kernelarch.debianarch]]
-  name = 'powerpc'
-  [[kernelarch.debianarch]]
-  name = 'ppc64'
-  [[kernelarch.debianarch]]
-  name = 'ppc64el'
-
-[[kernelarch]]
