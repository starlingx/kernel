-
-[[kernelarch]]
-name = 'loongarch'
-  [[kernelarch.debianarch]]
-  name = 'loong64'
-
-[[kernelarch]]
-name = 'm68k'
-  [[kernelarch.debianarch]]
-  name = 'm68k'
-
-[[kernelarch]]
-name = 'mips'
