@@ -44,6 +44,8 @@ KDIR ?= $(srctree)
 ifneq ($(KDIR),)
   LINUX=$(KDIR)
   LINUXSRC=$(LINUX)
+else ifneq ($(LINUX),)
+  KDIR=$(LINUX)
 endif
 
 ifeq ($M,)
diff --git a/bnxt_en-1.10.3-236.1.155.0/bnxt.c b/bnxt_en-1.10.3-236.1.155.0/bnxt.c
index 766cbe4..01f228a 100644
--- a/bnxt_en-1.10.3-236.1.155.0/bnxt.c
+++ b/bnxt_en-1.10.3-236.1.155.0/bnxt.c
@@ -21130,8 +21130,13 @@ static int bnxt_udp_tunnel_unset_port(struct net_device *netdev, unsigned int ta
 static const struct udp_tunnel_nic_info bnxt_udp_tunnels = {
 	.set_port	= bnxt_udp_tunnel_set_port,
 	.unset_port	= bnxt_udp_tunnel_unset_port,
-	.flags		= UDP_TUNNEL_NIC_INFO_MAY_SLEEP |
-			  UDP_TUNNEL_NIC_INFO_OPEN_ONLY,
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	.flags		= UDP_TUNNEL_NIC_INFO_OPEN_ONLY,
+#else
+ 	.flags		= UDP_TUNNEL_NIC_INFO_MAY_SLEEP |
+ 			  UDP_TUNNEL_NIC_INFO_OPEN_ONLY,
+#endif
 	.tables		= {
 		{ .n_entries = 1, .tunnel_types = UDP_TUNNEL_TYPE_VXLAN,  },
 		{ .n_entries = 1, .tunnel_types = UDP_TUNNEL_TYPE_GENEVE, },
@@ -21139,8 +21144,12 @@ static const struct udp_tunnel_nic_info bnxt_udp_tunnels = {
 }, bnxt_udp_tunnels_p7 = {
 	.set_port	= bnxt_udp_tunnel_set_port,
 	.unset_port	= bnxt_udp_tunnel_unset_port,
-	.flags		= UDP_TUNNEL_NIC_INFO_MAY_SLEEP |
-			  UDP_TUNNEL_NIC_INFO_OPEN_ONLY,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	.flags		= UDP_TUNNEL_NIC_INFO_OPEN_ONLY,
+#else
+ 	.flags		= UDP_TUNNEL_NIC_INFO_MAY_SLEEP |
+ 			  UDP_TUNNEL_NIC_INFO_OPEN_ONLY,
+#endif
 	.tables		= {
 		{ .n_entries = 1, .tunnel_types = UDP_TUNNEL_TYPE_VXLAN,  },
 		{ .n_entries = 1, .tunnel_types = UDP_TUNNEL_TYPE_GENEVE, },
diff --git a/bnxt_en-1.10.3-236.1.155.0/bnxt_devlink.c b/bnxt_en-1.10.3-236.1.155.0/bnxt_devlink.c
index 1c9baed..dcd297a 100644
--- a/bnxt_en-1.10.3-236.1.155.0/bnxt_devlink.c
+++ b/bnxt_en-1.10.3-236.1.155.0/bnxt_devlink.c
@@ -596,10 +596,19 @@ __bnxt_dl_reporter_create(struct bnxt *bp,
 	struct devlink_health_reporter *reporter;
 
 #ifndef HAVE_DEVLINK_HEALTH_AUTO_RECOVER
-	reporter = devlink_health_reporter_create(bp->dl, ops, 0, bp);
+		/* v6.16: graceful_period parameter dropped. */
+	#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 16, 0)
+		reporter = devlink_health_reporter_create(bp->dl, ops, bp);
+	#else
+		reporter = devlink_health_reporter_create(bp->dl, ops, 0, bp);
+	#endif
 #else
-	reporter = devlink_health_reporter_create(bp->dl, ops, 0,
-						  !!ops->recover, bp);
+		/* v6.16: graceful_period parameter dropped. */
+	#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 16, 0)
+		reporter = devlink_health_reporter_create(bp->dl, ops, bp);
+	#else
+		reporter = devlink_health_reporter_create(bp->dl, ops, 0, !!ops->recover, bp);
+	#endif
 #endif
 	if (IS_ERR(reporter)) {
 		netdev_warn(bp->dev, "Failed to create %s health reporter, rc = %ld\n",
diff --git a/bnxt_en-1.10.3-236.1.155.0/bnxt_ethtool.c b/bnxt_en-1.10.3-236.1.155.0/bnxt_ethtool.c
index 6866600..f9cbacf 100644
--- a/bnxt_en-1.10.3-236.1.155.0/bnxt_ethtool.c
+++ b/bnxt_en-1.10.3-236.1.155.0/bnxt_ethtool.c
@@ -4185,8 +4185,19 @@ static int bnxt_get_fecparam(struct net_device *dev,
 }
 
 #ifdef ETHTOOL_MAX_LANES
+/*
+ * v6.18: ethtool_ops::get_fec_stats() gained a third parameter
+ *        (struct ethtool_fec_hist *).  We do not populate the histogram
+ *        so just accept the new prototype and ignore it.
+ */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
 static void bnxt_get_fec_stats(struct net_device *dev,
-			       struct ethtool_fec_stats *fec_stats)
+			       struct ethtool_fec_stats *fec_stats,
+			       struct ethtool_fec_hist *hist)
+#else
+ static void bnxt_get_fec_stats(struct net_device *dev,
+ 			       struct ethtool_fec_stats *fec_stats)
+#endif
 {
 	struct bnxt *bp = netdev_priv(dev);
 	u64 *rx;
diff --git a/bnxt_en-1.10.3-236.1.155.0/bnxt_ktls.c b/bnxt_en-1.10.3-236.1.155.0/bnxt_ktls.c
index aef8c2a..86f7223 100644
--- a/bnxt_en-1.10.3-236.1.155.0/bnxt_ktls.c
+++ b/bnxt_en-1.10.3-236.1.155.0/bnxt_ktls.c
@@ -1449,18 +1449,44 @@ void bnxt_ktls_rx(struct bnxt *bp, struct sk_buff *skb, u8 *data_ptr,
 				nexthdr = hp->nexthdr;
 			}
 			th = (struct tcphdr *)nextp;
-			sk = __inet6_lookup_established(net,
-					net->ipv4.tcp_death_row.hashinfo,
-					&ip6h->saddr, th->source, &ip6h->daddr,
-					ntohs(th->dest), dev->ifindex, 0);
+		/*
+		 * v6.18: hashinfo argument removed; lookup picks
+		 *        net->ipv4.tcp_death_row.hashinfo internally.
+		 */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+		sk = __inet6_lookup_established(net,
+						&ip6h->saddr, th->source, &ip6h->daddr,
+						ntohs(th->dest),
+						dev->ifindex, 0);
+#else
+ 		sk = __inet6_lookup_established(net,
+ 						net->ipv4.tcp_death_row.hashinfo,
+ 						&ip6h->saddr, th->source, &ip6h->daddr,
+ 						ntohs(th->dest),
+ 						dev->ifindex, 0);
+#endif
 		} else {
 			struct iphdr *iph = (struct iphdr *)l3_ptr;
 
 			th = (struct tcphdr *)(l3_ptr + iph->ihl * 4);
+
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+			sk = inet_lookup_established(net,
+							iph->saddr, 
+							th->source,
+							iph->daddr, 
+							ntohs(th->dest),
+							dev->ifindex);
+#else
 			sk = inet_lookup_established(net,
 					net->ipv4.tcp_death_row.hashinfo,
-					iph->saddr, th->source, iph->daddr,
-					th->dest, dev->ifindex);
+					iph->saddr, 
+					th->source, 
+					iph->daddr,
+					th->dest, 
+					dev->ifindex);
+#endif
+
 		}
 		if (!sk)
 			goto rx_done_no_sk;
diff --git a/bnxt_en-1.10.3-236.1.155.0/bnxt_ptp.c b/bnxt_en-1.10.3-236.1.155.0/bnxt_ptp.c
index 31af26a..822c5f6 100644
--- a/bnxt_en-1.10.3-236.1.155.0/bnxt_ptp.c
+++ b/bnxt_en-1.10.3-236.1.155.0/bnxt_ptp.c
@@ -1337,7 +1337,15 @@ static void bnxt_ptp_timecounter_init(struct bnxt *bp, bool init_tc)
 
 	if (!ptp->ptp_clock) {
 		memset(&ptp->cc, 0, sizeof(ptp->cc));
-		ptp->cc.read = bnxt_cc_read;
+	/*
+	 * v6.16 made cyclecounter_read_t take a (const struct cyclecounter *).
+	 * Use a typeof() cast so the same line works on both old and new.
+	 */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 16, 0)
+	ptp->cc.read = (typeof(ptp->cc.read))bnxt_cc_read;
+#else
+	ptp->cc.read = bnxt_cc_read;
+#endif
 		if (bp->flags & BNXT_FLAG_CHIP_P5_PLUS)
 			ptp->cc.mask = CYCLECOUNTER_MASK(48);
 		else
diff --git a/bnxt_en-1.10.3-236.1.155.0/bnxt_xdp.c b/bnxt_en-1.10.3-236.1.155.0/bnxt_xdp.c
index e92c4bb..192bcbf 100644
--- a/bnxt_en-1.10.3-236.1.155.0/bnxt_xdp.c
+++ b/bnxt_en-1.10.3-236.1.155.0/bnxt_xdp.c
@@ -632,10 +632,27 @@ bnxt_xdp_build_skb(struct bnxt *bp, struct sk_buff *skb, u8 num_frags,
 			skb->csum_level = RX_CMP_ENCAP(rxcmp1);
 		}
 	}
+
+	/*
+	 * v6.18: xdp_update_skb_shared_info() was renamed to
+	 * xdp_update_skb_frags_info() and the last argument changed from
+	 * a bool pfmemalloc flag to a u32 word of xdp flags.
+	 * xdp_buff_is_frag_pfmemalloc() was removed; xdp_buff_get_skb_flags()
+	 * returns the full flags word (which encodes pfmemalloc and unreadable).
+	 */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	xdp_update_skb_frags_info(skb, num_frags,
+				  sinfo->xdp_frags_size,
+				  BNXT_RX_PAGE_SIZE * sinfo->nr_frags,
+				  xdp_buff_get_skb_flags(xdp));
+#else
 	xdp_update_skb_shared_info(skb, num_frags,
 				   sinfo->xdp_frags_size,
 				   BNXT_RX_PAGE_SIZE * sinfo->nr_frags,
 				   xdp_buff_is_frag_pfmemalloc(xdp));
+#endif
+
+
 	return skb;
 }
 #endif
diff --git a/bnxt_re-236.1.155.0/Makefile b/bnxt_re-236.1.155.0/Makefile
index d643b29..cf7f8ca 100644
--- a/bnxt_re-236.1.155.0/Makefile
+++ b/bnxt_re-236.1.155.0/Makefile
@@ -874,6 +874,7 @@ OFED_INCLUDES := LINUXINCLUDE=' \
                 $(KCONFIG_H) \
                 -I$(OFA_KERNEL_PATH)/include \
 		-I$(OFA_KERNEL_PATH)/include/linux \
+                -I$(KDIR)/include \
                 -I$(OFA_KERNEL_PATH)/include/uapi \
 		 $$(if $$(CONFIG_XEN),-D__XEN_INTERFACE_VERSION__=$$(CONFIG_XEN_INTERFACE_VERSION)) \
 		 $$(if $$(CONFIG_XEN),-I$$(KSRC)/arch/x86/include/mach-xen) \
diff --git a/bnxt_re-236.1.155.0/main.c b/bnxt_re-236.1.155.0/main.c
index 7f9dc88..e85f0f2 100644
--- a/bnxt_re-236.1.155.0/main.c
+++ b/bnxt_re-236.1.155.0/main.c
@@ -33,7 +33,7 @@
  *
  * Description: Main component of the bnxt_re driver
  */
-
+#include <linux/version.h>
 #include <linux/inetdevice.h>
 #include <linux/if_bonding.h>
 
@@ -50,6 +50,46 @@
 #include "hw_counters.h"
 #include "bnxt_dcb.h"
 
+
+/*
+ * v6.18 ib_device_ops compatibility shims:
+ *  - reg_user_mr        gained a struct ib_dmah *dmah arg.
+ *  - reg_user_mr_dmabuf gained struct ib_dmah *dmah and switched its
+ *    trailing argument from struct ib_udata * to struct uverbs_attr_bundle *.
+ * The driver doesn't act on the DMA hint, so we ignore dmah and dispatch to
+ * the existing 6.17-shaped functions.  attrs->driver_udata is the udata
+ * the inner functions still expect.
+ */
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+#include <rdma/ib_verbs.h>
+#include <rdma/uverbs_ioctl.h>
+
+static struct ib_mr *bnxt_re_reg_user_mr_v618(struct ib_pd *pd,
+					      u64 start, u64 length,
+					      u64 virt_addr, int access_flags,
+					      struct ib_dmah *dmah,
+					      struct ib_udata *udata)
+{
+	(void)dmah;
+	return bnxt_re_reg_user_mr(pd, start, length, virt_addr,
+				   access_flags, udata);
+}
+
+static struct ib_mr *bnxt_re_reg_user_mr_dmabuf_v618(struct ib_pd *pd,
+						     u64 offset, u64 length,
+						     u64 virt_addr, int fd,
+						     int access_flags,
+						     struct ib_dmah *dmah,
+						     struct uverbs_attr_bundle *attrs)
+{
+	(void)dmah;
+	return bnxt_re_reg_user_mr_dmabuf(pd, offset, length, virt_addr, fd,
+					  access_flags, &attrs->driver_udata);
+}
+#endif /* >= 6.18 */
+
+
+
 static char version[] =
 		"Broadcom NetXtreme-C/E RoCE Driver " ROCE_DRV_MODULE_NAME \
 		" v" ROCE_DRV_MODULE_VERSION " (" ROCE_DRV_MODULE_RELDATE ")\n";
@@ -3369,6 +3409,13 @@ static const struct ib_device_ops bnxt_re_dev_ops = {
 	.resize_cq		= bnxt_re_resize_cq,
 	.poll_cq		= bnxt_re_poll_cq,
 	.req_notify_cq		= bnxt_re_req_notify_cq,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	.reg_user_mr		= bnxt_re_reg_user_mr_v618,
+	.reg_user_mr_dmabuf	= bnxt_re_reg_user_mr_dmabuf_v618,
+#else
+ 	.reg_user_mr		= bnxt_re_reg_user_mr,
+ 	.reg_user_mr_dmabuf	= bnxt_re_reg_user_mr_dmabuf,
+#endif
 
 	.get_dma_mr		= bnxt_re_get_dma_mr,
 	.dereg_mr		= bnxt_re_dereg_mr,
@@ -3380,9 +3427,19 @@ static const struct ib_device_ops bnxt_re_dev_ops = {
 #endif
 	.alloc_mw		= bnxt_re_alloc_mw,
 	.dealloc_mw		= bnxt_re_dealloc_mw,
-	.reg_user_mr		= bnxt_re_reg_user_mr,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	.reg_user_mr		= bnxt_re_reg_user_mr_v618,
+#else
+ 	.reg_user_mr		= bnxt_re_reg_user_mr,
+#endif
+
 #ifdef HAVE_IB_UMEM_DMABUF
-	.reg_user_mr_dmabuf     = bnxt_re_reg_user_mr_dmabuf,
+#if LINUX_VERSION_CODE >= KERNEL_VERSION(6, 18, 0)
+	.reg_user_mr_dmabuf	= bnxt_re_reg_user_mr_dmabuf_v618,
+#else
+ 	.reg_user_mr_dmabuf	= bnxt_re_reg_user_mr_dmabuf,
+#endif
+
 #endif
 #ifdef HAVE_IB_REREG_USER_MR
 	/*
