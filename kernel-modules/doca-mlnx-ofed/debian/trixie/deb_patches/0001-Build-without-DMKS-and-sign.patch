From bf0d2d80db84b4176407679e037d45c759f45fff Mon Sep 17 00:00:00 2001
From: Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>
Date: Thu, 11 Jun 2026 19:30:34 +0300
Subject: [PATCH 1/3] Build without DKMS and sign

Disable DKMS and enable module signing. Export MODULE_SIGN_PRIV_KEY and
MODULE_SIGN_PUB_KEY so that the ofed_scripts/tools/sign-modules script
can locate the signing keys provided by the linux-*-keys package.

Signed-off-by: Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>
---
 debian/rules | 8 ++++++--
 1 file changed, 6 insertions(+), 2 deletions(-)

diff --git a/debian/rules b/debian/rules
index 1074cf1..5f22d35 100755
--- a/debian/rules
+++ b/debian/rules
@@ -17,8 +17,8 @@
 
 -include /usr/share/dpkg/architecture.mk
 
-WITH_DKMS ?= 1
-WITH_MOD_SIGN ?= 0
+WITH_DKMS ?= 0
+WITH_MOD_SIGN ?= 1
 MLXNUMC = $(shell grep ^processor /proc/cpuinfo | wc -l)
 NJOBS ?= $(shell if [ $(MLXNUMC) -lt 16 ]; then echo $(MLXNUMC); else echo 16; fi)
 ifeq ($(WITH_DKMS),1)
@@ -55,6 +55,10 @@ kernelver ?= $(shell uname -r)
 kernelver1 = $(shell echo $(kernelver) | sed -e 's/_/-/g')
 kernel_source_dir ?= "/lib/modules/$(kernelver)/build"
 deb_arch = $(shell uname -m)
+
+kernels_key_dir = /usr/src/kernels/$(kernelver)
+export MODULE_SIGN_PRIV_KEY = $(kernels_key_dir)/signing_key.pem
+export MODULE_SIGN_PUB_KEY = $(kernels_key_dir)/signing_key.x509
 
 %:
 ifeq ($(WITH_DKMS),1)
-- 
