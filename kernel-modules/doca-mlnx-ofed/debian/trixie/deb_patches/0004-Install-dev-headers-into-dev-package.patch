From 9a2e1f4c5b6d7e8f0a1b2c3d4e5f6a7b8c9d0e1f Mon Sep 17 00:00:00 2001
From: Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>
Date: Thu, 12 Jun 2026 10:00:00 +0300
Subject: [PATCH 4/4] Install dev headers into mlnx-ofed-kernel-dev package

The debian/rules uses $(pdkms) which resolves to mlnx-ofed-kernel-modules
when WITH_DKMS=0, but the ofa_kernel development headers should be
installed into the mlnx-ofed-kernel-dev package so that consumers like
bnxt-en can find them at /usr/src/ofa_kernel/.

Add a pdev variable and redirect the header installation accordingly.

The binary package names in debian/control carry the @KERNEL_TYPE@
suffix (mlnx-ofed-kernel-modules@KERNEL_TYPE@ /
mlnx-ofed-kernel-dev@KERNEL_TYPE@), so the pdkms and pdev variables in
the non-DKMS branch must use the same suffix. Otherwise dh_installdirs
is invoked with an unknown package name (e.g. mlnx-ofed-kernel-dev
instead of mlnx-ofed-kernel-dev-rt) and the build aborts.

Signed-off-by: Catalin Rapiteanu <viorel-catalin.rapiteanu@windriver.com>
---
 debian/rules | 19 +++++++++++++------
 1 file changed, 11 insertions(+), 8 deletions(-)

diff --git a/debian/rules b/debian/rules
index 273f220..b3e4f12 100755
--- a/debian/rules
+++ b/debian/rules
@@ -33,8 +33,10 @@ pname:=mlnx-ofed-kernel
 psource:=$(pname)-source
 ifeq ($(WITH_DKMS),1)
 pdkms:=$(pname)-dkms
+pdev:=$(pname)-dkms
 else
-pdkms:=$(pname)-modules
+pdkms:=$(pname)-modules@KERNEL_TYPE@
+pdev:=$(pname)-dev@KERNEL_TYPE@
 endif
 putils:=$(pname)-utils
 
@@ -120,12 +122,14 @@ ifeq ($(WITH_DKMS),1)
 	dh_installdirs -p$(pdkms)  usr/src/ofa_kernel/
 	# copy the ofa-kernel build headers using ofed_scripts/pre_build.sh in the DKMS MAKE step (called from ofed_scripts/pre_build.sh).
 else
-	dh_installdirs -p$(pdkms)  $(mod_dev_dir)
-	cp -a include/			debian/$(pdkms)$(mod_dev_dir)
-	cp -a config*			debian/$(pdkms)$(mod_dev_dir)
-	cp -a compat*			debian/$(pdkms)$(mod_dev_dir)
-	cp -a ofed_scripts		debian/$(pdkms)$(mod_dev_dir)
-	cp -a Module*.symvers		debian/$(pdkms)$(mod_dev_dir)
+	dh_installdirs -p$(pdev)  $(mod_dev_dir)
+	cp -a include/			debian/$(pdev)$(mod_dev_dir)
+	cp -a config*			debian/$(pdev)$(mod_dev_dir)
+	cp -a compat*			debian/$(pdev)$(mod_dev_dir)
+	cp -a ofed_scripts		debian/$(pdev)$(mod_dev_dir)
+	cp -a Module*.symvers		debian/$(pdev)$(mod_dev_dir)
+	dh_installdirs -p$(pdev)  usr/src/ofa_kernel
+	ln -sf /$(mod_dev_dir) debian/$(pdev)/usr/src/ofa_kernel/default
 endif
 
 	# Force DKMS to install our modules.
