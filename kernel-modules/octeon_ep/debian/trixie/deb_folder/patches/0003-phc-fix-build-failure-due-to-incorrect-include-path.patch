From 4e48a3fdf722ed9cd18d6b1836d4b46ab639e64f Mon Sep 17 00:00:00 2001
From: Ionut Nechita <ionut.nechita@windriver.com>
Date: Thu, 11 Jun 2026 17:57:18 +0300
Subject: [PATCH] phc: fix build failure due to incorrect include path

The PHC driver fails to compile when built via kbuild because
"override EXTRA_CFLAGS" with $(shell pwd) evaluates to the kernel
build directory instead of the module source directory when
KERNELRELEASE is set.

Use the kbuild-native ccflags-y variable with $(src), which kbuild
sets to the module's source directory.

Reference:
* https://github.com/MarvellEmbeddedProcessors/pcie_ep_octeon_host/issues/5

Signed-off-by: Ionut Nechita <ionut.nechita@windriver.com>
---
 drivers/phc/Makefile | 2 +-
 1 file changed, 1 insertion(+), 1 deletion(-)

diff --git a/drivers/phc/Makefile b/drivers/phc/Makefile
index 5c55f7c..926002c 100644
--- a/drivers/phc/Makefile
+++ b/drivers/phc/Makefile
@@ -22,7 +22,7 @@ endif
 OCT_DRIVER := oct_ep_phc
 OCT_INSTALL_DIR=/lib/modules/$(KVER)/updates/drivers/net/ethernet/marvell/$(OCT_DRIVER)
 
-override EXTRA_CFLAGS += -g -Werror -Wno-error=date-time -Wno-error=unused-variable -Wno-error=unused-function -I$(shell pwd)/include
+ccflags-y += -g -Werror -Wno-error=date-time -Wno-error=unused-variable -Wno-error=unused-function -I$(src)/include
 
 cflags-y += $(EXTRA_CFLAGS)
 
-- 
2.47.3

